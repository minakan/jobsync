    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "types": [
      "expo-router"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ]
    }
  },
  "include": [
    "src",
    "expo-env.d.ts"
  ]
}
