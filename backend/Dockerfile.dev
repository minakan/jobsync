# ==========================================
# JobSync Backend — 開発用 Dockerfile (uv)
# ==========================================
FROM python:3.12-slim

# uv インストール
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

WORKDIR /app

# 依存関係ファイルを先にコピー（レイヤーキャッシュ活用）
COPY pyproject.toml ./

# uv sync で仮想環境を作成して依存関係をインストール
# --no-install-project: アプリ本体は volumes でマウントするので不要
RUN uv sync --no-install-project

# パスに仮想環境を追加
ENV PATH="/app/.venv/bin:$PATH"

# アプリケーションコードは docker-compose の volumes でマウント
# （ホットリロード対応のため COPY しない）

EXPOSE 8000

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
